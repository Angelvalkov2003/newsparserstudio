# Copy to ".env" in the project root (same folder as docker-compose.yml) if you want overrides.
# Rebuild frontend after changes: docker compose build frontend && docker compose up -d frontend
#
# VITE_API_ORIGIN — URL of this project's API as seen from the browser (localhost:8000 from the host).
#
# Do NOT set VITE_TWELVE_PUNTO_API_ORIGIN unless the Twelve Punto API sends CORS headers for your site.
# Leave it unset so the built app calls same-origin /twelve-punto-api and nginx proxies (see frontend/nginx.conf).

VITE_API_ORIGIN=http://127.0.0.1:8000
